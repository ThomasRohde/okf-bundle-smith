{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PLUGIN_ROOT}/hooks/okf_session_context.py",
            "statusMessage": "Loading OKF bundle guidance",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${PLUGIN_ROOT}/hooks/okf_stop_review.py",
            "statusMessage": "Checking OKF bundle quality gates",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
